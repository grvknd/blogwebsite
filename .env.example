# API Configuration  
# Note: VITE_ prefix is required for variables to be accessible in frontend code
VITE_API_BASE_URL=http://localhost:5174

# JSON Server Configuration
JSON_SERVER_PORT=5174

# Database Path (adjust path for your system)
DB_PATH=C:/ui/w8/web/db1.json

# External Services
VITE_YOUTUBE_THUMBNAIL_BASE_URL=https://img.youtube.com/vi

# Environment
NODE_ENV=development
VITE_NODE_ENV=development

# Optional: Add more configuration as needed
# VITE_APP_NAME=My Blog App
# VITE_APP_VERSION=1.0.0
# VITE_LOG_LEVEL=debug